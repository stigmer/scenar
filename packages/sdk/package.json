{
  "name": "@scenar/sdk",
  "version": "0.0.1",
  "description": "Typed authoring surface for Scenar scenarios — createScenario() builder and proto adapter.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "lint": "echo 'lint placeholder'",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "sideEffects": false,
  "license": "Apache-2.0",
  "dependencies": {
    "@scenar/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stigmer/scenar.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["scenar", "scenario", "sdk", "createScenario", "proto", "authoring"]
}
