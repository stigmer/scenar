{
  "name": "@scenar/react",
  "version": "0.0.1",
  "description": "React components and hooks for the Scenar scenario playback engine.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css",
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --build && cp src/theme/tokens.css dist/theme.css && tailwindcss -i src/styles/index.css -o dist/styles.css --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "lint": "echo 'lint placeholder'",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "sideEffects": ["./dist/theme.css", "./dist/styles.css"],
  "license": "Apache-2.0",
  "dependencies": {
    "@scenar/core": "workspace:*"
  },
  "peerDependencies": {
    "framer-motion": ">=11.0.0",
    "lucide-react": ">=0.400.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stigmer/scenar.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["scenar", "scenario", "react", "demo", "playback", "interactive", "components"]
}
